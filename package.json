{
  "name": "@dsplayground/analytics-sdk",
  "version": "0.1.0",
  "description": "SDK de analytics em tempo real (Web Vitals, eventos de navegacao, custom events). Envia via Socket.IO autenticado por publishable_key + JWT.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "node scripts/smoke-bundle.mjs",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "socket.io-client": "^4.8.3",
    "uuid": "^13.0.0",
    "web-vitals": "^4.2.4"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^26.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^5.6.0",
    "vite": "^7.3.2",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "analytics",
    "web-vitals",
    "rum",
    "real-user-monitoring",
    "socket.io",
    "telemetry"
  ],
  "license": "MIT",
  "homepage": "https://github.com/danpqdan/dsplayground-analytics-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danpqdan/dsplayground-analytics-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/danpqdan/dsplayground-analytics-sdk/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
